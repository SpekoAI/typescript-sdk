{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": ".tsbuildinfo/publish.tsbuildinfo",
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@spekoai/contracts": ["../contracts/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "src/**/test-helpers.ts"],
  "references": [
    {
      "path": "../contracts/tsconfig.lib.json"
    }
  ]
}
